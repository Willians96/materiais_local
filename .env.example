# Banco de dados MySQL/MariaDB
# ATENÇÃO: copie este arquivo para .env e preencha com seus valores reais
# NUNCA commite o arquivo .env no git (já está no .gitignore)

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=materiais_local
DB_USER=materiais
DB_PASS=Trocar-senha-forte-aqui

# Ambiente: development | production
APP_ENV=development

# Caminho base da aplicação (subdiretório do Apache)
APP_BASE_PATH=/new/

# Timezone
APP_TIMEZONE=America/Sao_Paulo
