    <script>
        document.getElementById('btn-recolhe-menu').addEventListener('click', function() {
            // Alterna a classe 'recolhido' no aside
            document.querySelector('aside').classList.toggle('recolhido');
            // Alterna a classe 'recolhido' no botão
            document.querySelector('.recolhe__menu').classList.toggle('recolhido');
            document.querySelector(".body__cpi").classList.toggle("recolhido");
            document.querySelector(".aside__footer").classList.toggle("recolhido");
        });


        document.getElementById('searchButton').addEventListener('click', function() {
            const form = document.querySelector('.float__busca_pm');
            const formPosition = form.style.top === "60px" ? "-40%" : "60px";

            // Alterando a posição do formulário
            form.style.top = formPosition;
        });


        /** Botao de app cpi */
        const btnApp = document.getElementById('btn-app-cpi');
        const menu = document.getElementById('float__menu_aplicacoes');
        const btnFecharApp = document.getElementById('btn-fechar-app');

        // Adiciona um evento de clique no botão
        btnApp.addEventListener('click', function() {
            // Alterna a classe 'show' no menu para mostrar ou esconder
            menu.classList.toggle('show');
        });


        btnFecharApp.addEventListener('click', function() {
            menu.classList.toggle('show');
        });


        //carregar url da pagina
        const urlCompleta = window.location.href;
        document.getElementById('buscapm_url').value = urlCompleta;
    </script>

    <script>
        //impersonate
        const btn = document.getElementById('btn-toggle-impersonate');
        const container = document.getElementById('container-impersonate');

        btn.addEventListener('click', (e) => {
            e.stopPropagation(); // para não disparar o clique fora
            container.classList.toggle('active');
        });

        // Fecha ao clicar fora do formulário e do botão
        document.addEventListener('click', (e) => {
            if (container.classList.contains('active')) {
                // Se o clique NÃO for no container nem no botão
                if (!container.contains(e.target) && e.target !== btn) {
                    container.classList.remove('active');
                }
            }
        });
    </script>


