  atualizarCampos();

  function atualizarCampos() {
    let sexo = document.getElementById("sexo").value;
    let flexao = document.getElementById("flexao_barra");
    let isometria = document.getElementById("isometria_barra");

    if (sexo === "M") {
      flexao.disabled = false;
      isometria.disabled = true;
      isometria.value = ""; // Limpa o campo
    } else {
      flexao.disabled = true;
      flexao.value = ""; // Limpa o campo
      isometria.disabled = false;
    }
  }



  function calcularTAFMasculino()
  {
    let idade = document.getElementById('idade').value;
    let flexao_barra = document.getElementById('flexao_barra').value;
    let isometria_barra = document.getElementById('isometria_barra').value;
    let corrida = document.getElementById('corrida').value;
    let apoio_frente = document.getElementById('apoio_frente').value;
    let corrida_50m = document.getElementById('corrida_50m').value;
    let abdominal_remador = document.getElementById('abdominal_remador').value;
    let pontuacao = document.getElementById('pontuacao').value;
    let conceito = document.getElementById('conceito').value;



  }


</script>